{
  "permissions": {
    "allow": [
      "Read(*)",
      "Glob(*)",
      "Grep(*)",
      "Edit(*)",
      "Write(*)",
      "NotebookEdit(*)",
      "Bash(*)",
      "Task(*)",
      "WebFetch(*)",
      "WebSearch(*)"
    ],
    "deny": [],
    "ask": [
      "Bash(sudo rm -rf /*)",
      "Bash(sudo rm -rf /etc*)",
      "Bash(sudo rm -rf /var*)",
      "Bash(sudo rm -rf /usr*)",
      "Bash(mkfs*)",
      "Bash(dd if=/dev/zero*)",
      "Bash(chmod -R 777 /*)",
      "Bash(chown -R * /*)"
    ]
  }
}
